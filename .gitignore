# --- Security & Secrets ---
# Never commit sensitive credentials or environment variables.
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env.local
.env*.local
*.secret
*.key
*.pem
*.cert

# --- Dependencies & Packages ---
# Exclude auto-generated dependency directories.
node_modules/
jspm_packages/
.pnp
.pnp.js
.yarn-integrity

# --- OS Metadata ---
# System-specific metadata that doesn't belong in the repo.
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# --- Build & Output ---
# Exclude build artifacts and temporary distribution files.
dist/
build/
out/
.next/
.serverless/
.fusebox/
.dynamodb/
.terraform/
*.exe
*.dll
*.so
*.dylib

# --- IDEs & Editors ---
# Developer-specific configuration files.
.vscode/
!.vscode/extensions.json
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace
.project
.classpath
.settings/

# --- Logs & Runtime ---
# Temporary runtime outputs.
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.eslintcache
.stylelintcache
.node_repl_history

# --- Large Assets & Documentation ---
# Large files should usually be managed via LFS or external storage.
*.pdf
# Preview or scratch files
/hanatour-components.html
/tmp/
/temp/

# --- Local Settings ---
.next-boost-cache.json
package-lock.json.bak
yarn.lock.bak

